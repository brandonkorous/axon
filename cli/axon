#!/usr/bin/env bash
# Axon CLI — Self-hosted AI Command Center
# https://useaxon.dev

set -euo pipefail

# Version: read from VERSION file if available, otherwise hardcoded
AXON_VERSION_FILE="$(cd "$(dirname "$0")/.." 2>/dev/null && pwd)/VERSION"
if [ -f "$AXON_VERSION_FILE" ]; then
  AXON_VERSION="$(cat "$AXON_VERSION_FILE")"
else
  AXON_VERSION="0.1.0"
fi
AXON_REPO="brandonkorous/axon"
AXON_IMAGE_PREFIX="ghcr.io/${AXON_REPO}"
AXON_MARKER=".axon"

# ── Colors & Output ────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
CYAN='\033[0;36m'
DIM='\033[2m'
BOLD='\033[1m'
RESET='\033[0m'

info()    { printf "${CYAN}  ▸${RESET} %s\n" "$1"; }
ok()      { printf "${GREEN}  ✓${RESET} %s\n" "$1"; }
warn()    { printf "${YELLOW}  !${RESET} %s\n" "$1"; }
fail()    { printf "${RED}  ✗${RESET} %s\n" "$1"; exit 1; }
step()    { printf "\n${BOLD}  %s${RESET}\n" "$1"; }
ask()     { printf "${CYAN}  ?${RESET} %s " "$1"; }
spinner() {
  local pid=$1 msg=$2
  local frames='⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏'
  while kill -0 "$pid" 2>/dev/null; do
    for (( i=0; i<${#frames}; i++ )); do
      printf "\r${CYAN}  %s${RESET} %s" "${frames:$i:1}" "$msg"
      sleep 0.1
    done
  done
  printf "\r"
}

# ── Banner ──────────────────────────────────────────────────────────────────
banner() {
  printf "\n${BOLD}${CYAN}"
  printf "    ___   _  ______  _   __\n"
  printf "   /   | | |/ / __ \\/ | / /\n"
  printf "  / /| | |   / / / /  |/ / \n"
  printf " / ___ |/   / /_/ / /|  /  \n"
  printf "/_/  |_/_/|_\\____/_/ |_/   \n"
  printf "${RESET}"
  printf "  ${DIM}v${AXON_VERSION}${RESET}\n\n"
}

# ── Platform Detection ──────────────────────────────────────────────────────
detect_platform() {
  OS="$(uname -s)"
  case "$OS" in
    Linux*)  PLATFORM="linux" ;;
    Darwin*) PLATFORM="macos" ;;
    MINGW*|MSYS*|CYGWIN*) PLATFORM="windows" ;;
    *) fail "Unsupported OS: $OS" ;;
  esac
}

# ══════════════════════════════════════════════════════════════════════════════
#  Hardware Detection
# ══════════════════════════════════════════════════════════════════════════════

# Detect total system RAM in GB (integer)
detect_ram_gb() {
  local ram_kb=0
  case "$PLATFORM" in
    linux)
      ram_kb=$(grep MemTotal /proc/meminfo 2>/dev/null | awk '{print $2}')
      ;;
    macos)
      local ram_bytes
      ram_bytes=$(sysctl -n hw.memsize 2>/dev/null)
      ram_kb=$((ram_bytes / 1024))
      ;;
    windows)
      local ram_bytes
      ram_bytes=$(wmic.exe OS get TotalVisibleMemorySize /value 2>/dev/null | grep -o '[0-9]*')
      ram_kb=${ram_bytes:-0}
      ;;
  esac
  RAM_GB=$(( (ram_kb + 524288) / 1048576 ))  # round to nearest GB
}

# Detect GPU and VRAM. Sets GPU_NAME and GPU_VRAM_GB (0 if none found)
detect_gpu() {
  GPU_NAME=""
  GPU_VRAM_GB=0

  # Try nvidia-smi first (NVIDIA GPUs)
  if command -v nvidia-smi > /dev/null 2>&1; then
    GPU_NAME=$(nvidia-smi --query-gpu=name --format=csv,noheader 2>/dev/null | head -1)
    local vram_mb
    vram_mb=$(nvidia-smi --query-gpu=memory.total --format=csv,noheader,nounits 2>/dev/null | head -1)
    if [ -n "$vram_mb" ]; then
      GPU_VRAM_GB=$(( (vram_mb + 512) / 1024 ))
    fi
    return
  fi

  # macOS — check for Apple Silicon (unified memory, shared with GPU)
  if [ "$PLATFORM" = "macos" ]; then
    local chip
    chip=$(sysctl -n machdep.cpu.brand_string 2>/dev/null)
    if echo "$chip" | grep -qi "apple"; then
      GPU_NAME="$chip (unified memory)"
      GPU_VRAM_GB=$RAM_GB  # Apple Silicon shares RAM with GPU
    fi
    return
  fi

  # Windows — try wmic for any GPU
  if [ "$PLATFORM" = "windows" ]; then
    GPU_NAME=$(wmic.exe path win32_VideoController get name /value 2>/dev/null | grep -o '=.*' | sed 's/=//' | head -1 | tr -d '\r')
    local vram_bytes
    vram_bytes=$(wmic.exe path win32_VideoController get AdapterRAM /value 2>/dev/null | grep -o '[0-9]*' | head -1)
    if [ -n "$vram_bytes" ] && [ "$vram_bytes" -gt 0 ] 2>/dev/null; then
      GPU_VRAM_GB=$(( (vram_bytes + 536870912) / 1073741824 ))
    fi
  fi
}

# Detect available disk space in GB for the current directory
detect_disk_gb() {
  DISK_GB=0
  case "$PLATFORM" in
    linux|macos)
      DISK_GB=$(df -BG . 2>/dev/null | awk 'NR==2{print $4}' | tr -d 'G')
      ;;
    windows)
      DISK_GB=$(df -BG . 2>/dev/null | awk 'NR==2{print $4}' | tr -d 'G' || echo 0)
      ;;
  esac
}

# Print hardware summary
print_hardware_summary() {
  detect_ram_gb
  detect_gpu
  detect_disk_gb

  step "System hardware"
  info "RAM: ${RAM_GB} GB"

  if [ -n "$GPU_NAME" ]; then
    info "GPU: ${GPU_NAME}"
    info "VRAM: ${GPU_VRAM_GB} GB"
  else
    info "GPU: None detected"
  fi

  info "Disk available: ~${DISK_GB} GB"
}

# Recommend model tier based on hardware. Sets RECOMMENDED_TIER (1-4)
# Tier 1: minimal (8GB RAM, no GPU)     → llama3:8b only
# Tier 2: moderate (16GB RAM or 6GB+ VRAM) → + qwen2.5:7b
# Tier 3: strong (32GB RAM or 8GB+ VRAM)  → + qwen2.5:14b, mistral-small
# Tier 4: max (48GB+ RAM or 12GB+ VRAM)   → + llama3.1:70b, qwen2.5:32b
recommend_model_tier() {
  detect_ram_gb
  detect_gpu

  if [ "$GPU_VRAM_GB" -ge 12 ] 2>/dev/null || [ "$RAM_GB" -ge 48 ] 2>/dev/null; then
    RECOMMENDED_TIER=4
  elif [ "$GPU_VRAM_GB" -ge 8 ] 2>/dev/null || [ "$RAM_GB" -ge 32 ] 2>/dev/null; then
    RECOMMENDED_TIER=3
  elif [ "$GPU_VRAM_GB" -ge 6 ] 2>/dev/null || [ "$RAM_GB" -ge 16 ] 2>/dev/null; then
    RECOMMENDED_TIER=2
  else
    RECOMMENDED_TIER=1
  fi
}

# ══════════════════════════════════════════════════════════════════════════════
#  Docker Detection & Installation
# ══════════════════════════════════════════════════════════════════════════════

check_docker() {
  if command -v docker > /dev/null 2>&1; then
    return 0
  fi
  return 1
}

check_docker_running() {
  docker info > /dev/null 2>&1
}

check_docker_compose() {
  # Compose v2 (plugin)
  if docker compose version > /dev/null 2>&1; then
    COMPOSE_CMD="docker compose"
    return 0
  fi
  # Compose v1 (standalone)
  if command -v docker-compose > /dev/null 2>&1; then
    COMPOSE_CMD="docker-compose"
    return 0
  fi
  return 1
}

# ── Docker Install: macOS ───────────────────────────────────────────────────
install_docker_macos() {
  printf "\n"
  printf "  ${BOLD}Docker not found.${RESET} Axon needs Docker to run.\n"
  printf "  How would you like to install it?\n\n"
  printf "    ${BOLD}1)${RESET} Docker Desktop ${DIM}(recommended — GUI + CLI)${RESET}\n"
  printf "    ${BOLD}2)${RESET} Homebrew ${DIM}(brew install --cask docker)${RESET}\n"
  printf "    ${BOLD}3)${RESET} OrbStack ${DIM}(lightweight alternative)${RESET}\n"
  printf "    ${BOLD}s)${RESET} Skip — I'll install it myself\n\n"
  ask "Choose [1/2/3/s]:"
  read -r choice

  case "$choice" in
    1)
      info "Downloading Docker Desktop..."
      local arch
      arch="$(uname -m)"
      if [ "$arch" = "arm64" ]; then
        local url="https://desktop.docker.com/mac/main/arm64/Docker.dmg"
      else
        local url="https://desktop.docker.com/mac/main/amd64/Docker.dmg"
      fi
      local tmp="/tmp/Docker.dmg"
      curl -fSL "$url" -o "$tmp"
      info "Mounting installer..."
      hdiutil attach "$tmp" -quiet
      info "Installing... (you may be prompted for your password)"
      cp -R "/Volumes/Docker/Docker.app" /Applications/ 2>/dev/null || \
        sudo cp -R "/Volumes/Docker/Docker.app" /Applications/
      hdiutil detach "/Volumes/Docker" -quiet
      rm -f "$tmp"
      info "Starting Docker Desktop..."
      open /Applications/Docker.app
      wait_for_docker
      ;;
    2)
      if ! command -v brew > /dev/null 2>&1; then
        fail "Homebrew not found. Install it first: https://brew.sh"
      fi
      info "Installing Docker Desktop via Homebrew..."
      brew install --cask docker
      info "Starting Docker Desktop..."
      open /Applications/Docker.app
      wait_for_docker
      ;;
    3)
      if ! command -v brew > /dev/null 2>&1; then
        fail "Homebrew not found. Install it first: https://brew.sh"
      fi
      info "Installing OrbStack via Homebrew..."
      brew install --cask orbstack
      info "Starting OrbStack..."
      open /Applications/OrbStack.app
      wait_for_docker
      ;;
    s|S)
      printf "\n"
      info "Install Docker manually: https://docs.docker.com/get-docker/"
      info "Then re-run this command."
      exit 0
      ;;
    *)
      fail "Invalid choice"
      ;;
  esac
}

# ── Docker Install: Linux ──────────────────────────────────────────────────
install_docker_linux() {
  printf "\n"
  printf "  ${BOLD}Docker not found.${RESET} Axon needs Docker to run.\n"
  printf "  How would you like to install it?\n\n"
  printf "    ${BOLD}1)${RESET} Docker Engine ${DIM}(recommended — official install script)${RESET}\n"
  printf "    ${BOLD}2)${RESET} Docker Desktop ${DIM}(GUI + CLI, requires systemd)${RESET}\n"
  printf "    ${BOLD}s)${RESET} Skip — I'll install it myself\n\n"
  ask "Choose [1/2/s]:"
  read -r choice

  case "$choice" in
    1)
      info "Installing Docker Engine via official script..."
      info "This may ask for your sudo password."
      curl -fsSL https://get.docker.com | sudo sh
      # Add current user to docker group
      if ! groups | grep -q docker; then
        sudo usermod -aG docker "$USER"
        warn "Added $USER to docker group."
        warn "You may need to log out and back in for group changes to take effect."
        warn "Or run: newgrp docker"
      fi
      # Start Docker if not running
      if command -v systemctl > /dev/null 2>&1; then
        sudo systemctl start docker
        sudo systemctl enable docker
      fi
      wait_for_docker
      ;;
    2)
      info "Download Docker Desktop for Linux:"
      info "  https://docs.docker.com/desktop/install/linux-install/"
      info "Install the .deb or .rpm package, then re-run this command."
      exit 0
      ;;
    s|S)
      printf "\n"
      info "Install Docker manually: https://docs.docker.com/get-docker/"
      info "Then re-run this command."
      exit 0
      ;;
    *)
      fail "Invalid choice"
      ;;
  esac
}

# ── Docker Install: Windows (Git Bash / MSYS2) ─────────────────────────────
install_docker_windows() {
  printf "\n"
  printf "  ${BOLD}Docker not found.${RESET} Axon needs Docker to run.\n"
  printf "  How would you like to install it?\n\n"
  printf "    ${BOLD}1)${RESET} Docker Desktop ${DIM}(recommended)${RESET}\n"
  printf "    ${BOLD}2)${RESET} winget ${DIM}(winget install Docker.DockerDesktop)${RESET}\n"
  printf "    ${BOLD}s)${RESET} Skip — I'll install it myself\n\n"
  ask "Choose [1/2/s]:"
  read -r choice

  case "$choice" in
    1)
      info "Downloading Docker Desktop installer..."
      local url="https://desktop.docker.com/win/main/amd64/Docker%20Desktop%20Installer.exe"
      local tmp="/tmp/DockerDesktopInstaller.exe"
      curl -fSL "$url" -o "$tmp"
      info "Launching installer... Follow the prompts to complete installation."
      cmd.exe /c "$(cygpath -w "$tmp")" install --quiet 2>/dev/null || \
        start "$(cygpath -w "$tmp")" 2>/dev/null || \
        info "Open this file to install: $tmp"
      info "After installation completes, restart your terminal and re-run this command."
      exit 0
      ;;
    2)
      info "Installing via winget..."
      winget.exe install -e --id Docker.DockerDesktop || \
        fail "winget install failed. Try option 1 or install manually."
      info "Restart your terminal and re-run this command."
      exit 0
      ;;
    s|S)
      printf "\n"
      info "Install Docker Desktop: https://docs.docker.com/desktop/install/windows-install/"
      info "Then re-run this command."
      exit 0
      ;;
    *)
      fail "Invalid choice"
      ;;
  esac
}

# ── Wait for Docker daemon ──────────────────────────────────────────────────
wait_for_docker() {
  info "Waiting for Docker to be ready..."
  local attempts=0
  local max_attempts=60
  while ! docker info > /dev/null 2>&1; do
    attempts=$((attempts + 1))
    if [ "$attempts" -ge "$max_attempts" ]; then
      fail "Docker did not start within 60 seconds. Start it manually and retry."
    fi
    printf "\r${CYAN}  ⏳${RESET} Waiting for Docker... (%ds)" "$attempts"
    sleep 1
  done
  printf "\r"
  ok "Docker is running"
}

# ── Start Docker if installed but not running ───────────────────────────────
start_docker() {
  info "Docker is installed but not running. Starting..."
  case "$PLATFORM" in
    macos)
      open /Applications/Docker.app 2>/dev/null || \
        open /Applications/OrbStack.app 2>/dev/null || \
        fail "Could not start Docker. Launch Docker Desktop manually."
      ;;
    linux)
      if command -v systemctl > /dev/null 2>&1; then
        sudo systemctl start docker
      elif command -v service > /dev/null 2>&1; then
        sudo service docker start
      else
        fail "Could not start Docker. Start the daemon manually: sudo dockerd"
      fi
      ;;
    windows)
      # Try to start Docker Desktop
      cmd.exe /c "start \"\" \"C:\\Program Files\\Docker\\Docker\\Docker Desktop.exe\"" 2>/dev/null || \
        info "Start Docker Desktop from your Start menu."
      ;;
  esac
  wait_for_docker
}

# ── Ensure Docker is available ──────────────────────────────────────────────
ensure_docker() {
  step "Checking dependencies..."

  if ! check_docker; then
    case "$PLATFORM" in
      macos)   install_docker_macos ;;
      linux)   install_docker_linux ;;
      windows) install_docker_windows ;;
    esac

    # Re-check after install
    if ! check_docker; then
      fail "Docker installation did not complete. Install manually and retry."
    fi
  else
    ok "Docker installed"
  fi

  if ! check_docker_running; then
    start_docker
  else
    ok "Docker running"
  fi

  if ! check_docker_compose; then
    fail "Docker Compose not found. Install it: https://docs.docker.com/compose/install/"
  else
    ok "Docker Compose available"
  fi
}

# ══════════════════════════════════════════════════════════════════════════════
#  Workspace Templates
# ══════════════════════════════════════════════════════════════════════════════

write_compose_file() {
  local dir="$1"
  cat > "${dir}/docker-compose.yml" << 'COMPOSE'
# Axon — Docker Compose (managed by axon CLI)
# Docs: https://useaxon.dev

services:
  backend:
    image: ghcr.io/brandonkorous/axon-backend:latest
    ports:
      - "${AXON_PORT_BACKEND:-8000}:8000"
    volumes:
      - ${AXON_ORGS_DIR:-./orgs}:/orgs
      - /var/run/docker.sock:/var/run/docker.sock
    environment:
      - ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY:-}
      - OPENAI_API_KEY=${OPENAI_API_KEY:-}
      - DEFAULT_MODEL=${DEFAULT_MODEL:-anthropic/claude-sonnet-4-20250514}
      - OLLAMA_BASE_URL=http://ollama:11434
      - AXON_ORGS_DIR=/orgs
      - AXON_LOG_LEVEL=${AXON_LOG_LEVEL:-INFO}
      - DB_ENCRYPTION_KEY=${DB_ENCRYPTION_KEY:-}
    depends_on:
      ollama:
        condition: service_started
        required: false
    restart: unless-stopped

  frontend:
    image: ghcr.io/brandonkorous/axon-frontend:latest
    ports:
      - "${AXON_PORT_FRONTEND:-3000}:3000"
    depends_on:
      - backend
    restart: unless-stopped

  searxng:
    image: searxng/searxng:latest
    ports:
      - "${AXON_PORT_SEARCH:-8080}:8080"
    environment:
      - SEARXNG_BASE_URL=http://searxng:8080
    volumes:
      - searxng_data:/etc/searxng
    profiles:
      - web-search

  ollama:
    image: ollama/ollama:latest
    ports:
      - "${AXON_PORT_OLLAMA:-11434}:11434"
    volumes:
      - ollama_models:/root/.ollama
    profiles:
      - local-llm
    deploy:
      resources:
        reservations:
          devices:
            - driver: nvidia
              count: 1
              capabilities: [gpu]

  ollama-init:
    image: ollama/ollama:latest
    profiles:
      - local-llm
    depends_on:
      - ollama
    restart: "no"
    entrypoint: ["/bin/sh", "-c"]
    command:
      - |
        echo "Waiting for Ollama..."
        until curl -s http://ollama:11434/api/tags > /dev/null 2>&1; do sleep 1; done
        echo "Pulling models..."
        curl -s http://ollama:11434/api/pull -d '{"name":"llama3"}'
        curl -s http://ollama:11434/api/pull -d "{\"name\":\"${OLLAMA_MODEL:-qwen2.5:14b}\"}"
        echo "Models ready."
    environment:
      - OLLAMA_MODEL=${OLLAMA_MODEL:-qwen2.5:14b}

volumes:
  ollama_models:
  searxng_data:
COMPOSE
}

write_env_file() {
  local dir="$1"
  local api_key="${2:-}"
  cat > "${dir}/.env" << ENV
# Axon Configuration
# Docs: https://useaxon.dev

# ── API Keys (at least one required) ─────────────────────────────────────
ANTHROPIC_API_KEY=${api_key}
OPENAI_API_KEY=

# ── Model ─────────────────────────────────────────────────────────────────
# LiteLLM format: provider/model-name
DEFAULT_MODEL=anthropic/claude-sonnet-4-20250514

# ── Data ──────────────────────────────────────────────────────────────────
AXON_ORGS_DIR=./orgs

# ── Ports ─────────────────────────────────────────────────────────────────
AXON_PORT_FRONTEND=3000
AXON_PORT_BACKEND=8000

# ── Local LLMs (optional) ────────────────────────────────────────────────
# Enable with: axon start --local
OLLAMA_MODEL=qwen2.5:14b

# ── Database ──────────────────────────────────────────────────────────────
# Leave empty for SQLite (default). Postgres: postgresql+asyncpg://user:pass@host/axon
DATABASE_URL=

# ── Security ──────────────────────────────────────────────────────────────
# Auto-generated encryption key for OAuth token storage
DB_ENCRYPTION_KEY=$(python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())" 2>/dev/null || openssl rand -base64 32)
ENV
}

write_gitignore() {
  local dir="$1"
  cat > "${dir}/.gitignore" << 'GI'
.env
orgs/
*.db
GI
}

