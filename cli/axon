# ── Local model selection (interactive) ─────────────────────────────────────
select_local_model() {
  recommend_model_tier

  printf "\n"
  step "Local LLM Setup"
  printf "\n"
  info "RAM: ${RAM_GB} GB"
  if [ -n "$GPU_NAME" ]; then
    info "GPU: ${GPU_NAME} (${GPU_VRAM_GB} GB VRAM)"
  else
    info "GPU: None detected (models will run on CPU — slower but functional)"
  fi
  printf "\n"

  case "$RECOMMENDED_TIER" in
    1)
      printf "  ${YELLOW}${BOLD}Limited hardware detected.${RESET}\n"
      printf "  With ${RAM_GB} GB RAM, only small models will run reliably.\n\n"
      printf "    ${BOLD}1)${RESET} llama3:8b ${DIM}(~5 GB — recommended for your system)${RESET}\n"
      printf "    ${BOLD}2)${RESET} qwen2.5:7b ${DIM}(~4.5 GB — may be tight on memory)${RESET}\n"
      printf "    ${BOLD}3)${RESET} phi4-mini:3.8b ${DIM}(~2.5 GB — fastest, least capable)${RESET}\n"
      printf "    ${BOLD}c)${RESET} Custom model name\n\n"
      ;;
    2)
      printf "  ${CYAN}Moderate hardware detected.${RESET} Good for medium models.\n\n"
      printf "    ${BOLD}1)${RESET} qwen2.5:7b ${DIM}(~4.5 GB — recommended for your system)${RESET}\n"
      printf "    ${BOLD}2)${RESET} llama3:8b ${DIM}(~5 GB — solid general purpose)${RESET}\n"
      printf "    ${BOLD}3)${RESET} mistral:7b ${DIM}(~4.5 GB — fast reasoning)${RESET}\n"
      printf "    ${BOLD}4)${RESET} codellama:7b ${DIM}(~4 GB — code-focused)${RESET}\n"
      printf "    ${BOLD}c)${RESET} Custom model name\n\n"
      ;;
    3)
      printf "  ${GREEN}Strong hardware detected.${RESET} You can run larger models.\n\n"
      printf "    ${BOLD}1)${RESET} qwen2.5:14b ${DIM}(~9 GB — recommended for your system)${RESET}\n"
      printf "    ${BOLD}2)${RESET} mistral-small:22b ${DIM}(~13 GB — excellent reasoning)${RESET}\n"
      printf "    ${BOLD}3)${RESET} llama3:8b ${DIM}(~5 GB — lighter, faster)${RESET}\n"
      printf "    ${BOLD}4)${RESET} codellama:13b ${DIM}(~8 GB — code-focused)${RESET}\n"
      printf "    ${BOLD}c)${RESET} Custom model name\n\n"
      ;;
    4)
      printf "  ${GREEN}${BOLD}Excellent hardware detected.${RESET} You can run large models.\n\n"
      printf "    ${BOLD}1)${RESET} qwen2.5:32b ${DIM}(~20 GB — recommended for your system)${RESET}\n"
      printf "    ${BOLD}2)${RESET} llama3.1:70b ${DIM}(~40 GB — maximum capability)${RESET}\n"
      printf "    ${BOLD}3)${RESET} qwen2.5:14b ${DIM}(~9 GB — fast + capable)${RESET}\n"
      printf "    ${BOLD}4)${RESET} mistral-small:22b ${DIM}(~13 GB — strong reasoning)${RESET}\n"
      printf "    ${BOLD}c)${RESET} Custom model name\n\n"
      ;;
  esac

  ask "Choose model:"
  read -r model_choice

  case "$RECOMMENDED_TIER" in
    1)
      case "$model_choice" in
        1) LOCAL_MODEL="llama3:8b" ;;
        2) LOCAL_MODEL="qwen2.5:7b" ;;
        3) LOCAL_MODEL="phi4-mini:3.8b" ;;
        c|C) ask "Model name (e.g. mistral:7b):"; read -r LOCAL_MODEL ;;
        *) LOCAL_MODEL="llama3:8b"; warn "Defaulting to llama3:8b" ;;
      esac
      ;;
    2)
      case "$model_choice" in
        1) LOCAL_MODEL="qwen2.5:7b" ;;
        2) LOCAL_MODEL="llama3:8b" ;;
        3) LOCAL_MODEL="mistral:7b" ;;
        4) LOCAL_MODEL="codellama:7b" ;;
        c|C) ask "Model name (e.g. qwen2.5:14b):"; read -r LOCAL_MODEL ;;
        *) LOCAL_MODEL="qwen2.5:7b"; warn "Defaulting to qwen2.5:7b" ;;
      esac
      ;;
    3)
      case "$model_choice" in
        1) LOCAL_MODEL="qwen2.5:14b" ;;
        2) LOCAL_MODEL="mistral-small:22b" ;;
        3) LOCAL_MODEL="llama3:8b" ;;
        4) LOCAL_MODEL="codellama:13b" ;;
        c|C) ask "Model name (e.g. llama3.1:70b):"; read -r LOCAL_MODEL ;;
        *) LOCAL_MODEL="qwen2.5:14b"; warn "Defaulting to qwen2.5:14b" ;;
      esac
      ;;
    4)
      case "$model_choice" in
        1) LOCAL_MODEL="qwen2.5:32b" ;;
        2) LOCAL_MODEL="llama3.1:70b" ;;
        3) LOCAL_MODEL="qwen2.5:14b" ;;
        4) LOCAL_MODEL="mistral-small:22b" ;;
        c|C) ask "Model name (e.g. qwen2.5:32b):"; read -r LOCAL_MODEL ;;
        *) LOCAL_MODEL="qwen2.5:32b"; warn "Defaulting to qwen2.5:32b" ;;
      esac
      ;;
  esac

  ok "Selected model: ${LOCAL_MODEL}"
  info "llama3:8b will also be pulled as the navigator model"
}

# ── axon init <name> ────────────────────────────────────────────────────────
cmd_init() {
  local name="${1:-}"
  if [ -z "$name" ]; then
    fail "Usage: axon init <workspace-name>"
  fi

  banner

  detect_platform
  ensure_docker

  step "Creating workspace: ${name}/"

  if [ -d "$name" ] && [ -f "${name}/${AXON_MARKER}" ]; then
    fail "Axon workspace '${name}' already exists"
  fi

  mkdir -p "$name"

  # Ask for API key
  printf "\n"
  printf "  ${BOLD}Axon needs at least one LLM provider.${RESET}\n"
  printf "  You can always change this later in ${DIM}.env${RESET}\n\n"
  printf "    ${BOLD}1)${RESET} Anthropic Claude ${DIM}(recommended)${RESET}\n"
  printf "    ${BOLD}2)${RESET} OpenAI\n"
  printf "    ${BOLD}3)${RESET} Local only ${DIM}(Ollama — no API key needed)${RESET}\n"
  printf "    ${BOLD}s)${RESET} Skip — I'll configure later\n\n"
  ask "Choose [1/2/3/s]:"
  read -r provider_choice

  local api_key=""
  local use_local=false

  case "$provider_choice" in
    1)
      ask "Anthropic API key:"
      read -r api_key
      if [ -z "$api_key" ]; then
        warn "No key entered. You can add it later in .env"
      fi
      ;;
    2)
      ask "OpenAI API key:"
      read -r api_key
      ;;
    3)
      use_local=true
      select_local_model
      ;;
    s|S)
      info "Skipping API key setup. Edit .env before starting."
      ;;
    *)
      warn "Invalid choice — skipping. Edit .env before starting."
      ;;
  esac

  # Write workspace files
  write_compose_file "$name"
  write_env_file "$name" "$api_key"
  write_gitignore "$name"
  mkdir -p "${name}/orgs"

  # Write marker file
  printf '%s\n' "$AXON_VERSION" > "${name}/${AXON_MARKER}"

  # If OpenAI was chosen, swap the key placement
  if [ "$provider_choice" = "2" ] && [ -n "$api_key" ]; then
    sed -i.bak "s/^ANTHROPIC_API_KEY=.*/ANTHROPIC_API_KEY=/" "${name}/.env"
    sed -i.bak "s/^OPENAI_API_KEY=.*/OPENAI_API_KEY=${api_key}/" "${name}/.env"
    sed -i.bak "s/^DEFAULT_MODEL=.*/DEFAULT_MODEL=openai\/gpt-4o/" "${name}/.env"
    rm -f "${name}/.env.bak"
  fi

  # If local-only, set the model to the user's chosen Ollama model
  if [ "$use_local" = true ]; then
    local chosen_model="${LOCAL_MODEL:-llama3:8b}"
    sed -i.bak "s/^ANTHROPIC_API_KEY=.*/ANTHROPIC_API_KEY=/" "${name}/.env"
    sed -i.bak "s/^DEFAULT_MODEL=.*/DEFAULT_MODEL=ollama\/${chosen_model}/" "${name}/.env"
    sed -i.bak "s/^OLLAMA_MODEL=.*/OLLAMA_MODEL=${chosen_model}/" "${name}/.env"
    rm -f "${name}/.env.bak"
  fi

  ok "Workspace created"

  # Summary
  printf "\n"
  printf "  ${BOLD}${GREEN}Ready!${RESET}\n\n"
  printf "    ${CYAN}cd ${name}${RESET}\n"
  if [ "$use_local" = true ]; then
    printf "    ${CYAN}axon start --local${RESET}\n"
  else
    printf "    ${CYAN}axon start${RESET}\n"
  fi
  printf "\n"
  printf "  ${DIM}Open http://localhost:3000 after startup${RESET}\n\n"
}

# ── axon start ──────────────────────────────────────────────────────────────
cmd_start() {
  assert_workspace

  banner
  detect_platform
  ensure_docker

  step "Starting Axon..."

  local profiles=""
  for arg in "$@"; do
    case "$arg" in
      --local|--ollama)
        profiles="$profiles --profile local-llm"
        info "Local LLM mode enabled (Ollama)"
        ;;
      --search|--web-search)
        profiles="$profiles --profile web-search"
        info "Web search enabled (SearXNG)"
        ;;
    esac
  done

  $COMPOSE_CMD up -d $profiles

  printf "\n"
  ok "Axon is running"
  printf "\n"
  printf "  ${BOLD}Dashboard:${RESET}  ${CYAN}http://localhost:${AXON_PORT_FRONTEND:-3000}${RESET}\n"
  printf "  ${BOLD}API:${RESET}        ${CYAN}http://localhost:${AXON_PORT_BACKEND:-8000}${RESET}\n"
  printf "\n"
  printf "  ${DIM}Logs:  axon logs${RESET}\n"
  printf "  ${DIM}Stop:  axon stop${RESET}\n\n"
}

# ── axon stop ───────────────────────────────────────────────────────────────
cmd_stop() {
  assert_workspace

  step "Stopping Axon..."
  $COMPOSE_CMD down
  ok "Axon stopped"
}

# ── axon restart ────────────────────────────────────────────────────────────
cmd_restart() {
  assert_workspace
  cmd_stop
  cmd_start "$@"
}

# ── axon logs ───────────────────────────────────────────────────────────────
cmd_logs() {
  assert_workspace
  $COMPOSE_CMD logs -f "${1:-}"
}

# ── axon status ─────────────────────────────────────────────────────────────
cmd_status() {
  assert_workspace
  $COMPOSE_CMD ps
}

# ── axon update ─────────────────────────────────────────────────────────────
cmd_update() {
  assert_workspace

  step "Updating Axon..."
  $COMPOSE_CMD pull
  ok "Images updated"

  ask "Restart now? [Y/n]:"
  read -r restart
  case "$restart" in
    n|N|no) info "Run 'axon restart' when ready." ;;
    *) cmd_restart "$@" ;;
  esac
}

# ── axon doctor ─────────────────────────────────────────────────────────────
cmd_doctor() {
  banner
  detect_platform

  step "Checking system..."

  # Docker
  if check_docker; then
    ok "Docker installed ($(docker --version | head -1))"
  else
    fail "Docker not installed"
  fi

  if check_docker_running; then
    ok "Docker daemon running"
  else
    warn "Docker daemon not running"
  fi

  if check_docker_compose; then
    ok "Docker Compose available ($($COMPOSE_CMD version --short 2>/dev/null || echo "unknown"))"
  else
    warn "Docker Compose not found"
  fi

  # Workspace
  if [ -f "$AXON_MARKER" ]; then
    ok "Inside Axon workspace (v$(cat "$AXON_MARKER"))"
  else
    warn "Not inside an Axon workspace"
  fi

  # .env
  if [ -f ".env" ]; then
    ok ".env file present"
    if grep -q "ANTHROPIC_API_KEY=." .env 2>/dev/null || \
       grep -q "OPENAI_API_KEY=." .env 2>/dev/null; then
      ok "API key configured"
    else
      warn "No API key found in .env (needed unless using local LLMs only)"
    fi
  else
    warn "No .env file"
  fi

  # Hardware
  step "Checking hardware..."

  detect_ram_gb
  if [ "$RAM_GB" -ge 16 ] 2>/dev/null; then
    ok "RAM: ${RAM_GB} GB"
  elif [ "$RAM_GB" -ge 8 ] 2>/dev/null; then
    warn "RAM: ${RAM_GB} GB (16 GB+ recommended for local LLMs)"
  else
    warn "RAM: ${RAM_GB} GB (minimum 8 GB required, 16 GB+ recommended)"
  fi

  detect_gpu
  if [ -n "$GPU_NAME" ]; then
    ok "GPU: ${GPU_NAME}"
    if [ "$GPU_VRAM_GB" -ge 8 ] 2>/dev/null; then
      ok "VRAM: ${GPU_VRAM_GB} GB"
    elif [ "$GPU_VRAM_GB" -gt 0 ] 2>/dev/null; then
      warn "VRAM: ${GPU_VRAM_GB} GB (8 GB+ recommended for local LLMs)"
    fi
  else
    info "GPU: None detected (local LLMs will use CPU)"
  fi

  detect_disk_gb
  if [ "$DISK_GB" -ge 20 ] 2>/dev/null; then
    ok "Disk: ~${DISK_GB} GB available"
  else
    warn "Disk: ~${DISK_GB} GB available (20 GB+ recommended for model storage)"
  fi

  # Model recommendations
  recommend_model_tier
  printf "\n"
  case "$RECOMMENDED_TIER" in
    1) info "Local LLM tier: Basic — small models only (llama3:8b, phi4-mini)" ;;
    2) info "Local LLM tier: Moderate — medium models (qwen2.5:7b, mistral:7b)" ;;
    3) info "Local LLM tier: Strong — large models (qwen2.5:14b, mistral-small:22b)" ;;
    4) info "Local LLM tier: Excellent — very large models (qwen2.5:32b, llama3.1:70b)" ;;
  esac

  # Port availability
  step "Checking ports..."

  for port in 3000 8000; do
    if ! (echo > /dev/tcp/localhost/$port) 2>/dev/null; then
      ok "Port $port available"
    else
      warn "Port $port in use"
    fi
  done

  printf "\n"
}

# ── axon self-update ────────────────────────────────────────────────────────
cmd_self_update() {
  info "Updating Axon CLI..."
  local cli_url="https://raw.githubusercontent.com/${AXON_REPO}/main/cli/axon"
  local self_path
  self_path="$(command -v axon 2>/dev/null || echo "")"

  if [ -z "$self_path" ]; then
    fail "Cannot find axon in PATH"
  fi

  curl -fsSL "$cli_url" -o "$self_path.tmp"
  chmod +x "$self_path.tmp"
  mv "$self_path.tmp" "$self_path"
  ok "Updated to latest version"
}

# ── Helpers ─────────────────────────────────────────────────────────────────
assert_workspace() {
  # Load .env if present
  if [ -f ".env" ]; then
    set -a
    # shellcheck disable=SC1091
    . ./.env
    set +a
  fi

  if [ ! -f "$AXON_MARKER" ]; then
    fail "Not an Axon workspace. Run 'axon init <name>' first or cd into your workspace."
  fi

  if ! check_docker_compose; then
    fail "Docker Compose not found"
  fi
}

# ── axon version ────────────────────────────────────────────────────────────
cmd_version() {
  printf "  ${BOLD}CLI:${RESET}    %s\n" "$AXON_VERSION"

  # Try to get server version if running in a workspace
  if [ -f "$AXON_MARKER" ] && check_docker 2>/dev/null && check_docker_running 2>/dev/null; then
    local server_version
    server_version=$(curl -s "http://localhost:${AXON_PORT_BACKEND:-8000}/api/version" 2>/dev/null | \
      grep -o '"version":"[^"]*"' | cut -d'"' -f4)
    if [ -n "$server_version" ]; then
      printf "  ${BOLD}Server:${RESET} %s\n" "$server_version"
      if [ "$AXON_VERSION" != "$server_version" ]; then
        warn "Version mismatch — run 'axon update' to sync"
      fi
    else
      printf "  ${BOLD}Server:${RESET} ${DIM}not running${RESET}\n"
    fi
  fi
}

# ── Usage ───────────────────────────────────────────────────────────────────
usage() {
  banner
  printf "  ${BOLD}Usage:${RESET} axon <command> [options]\n\n"
  printf "  ${BOLD}Commands:${RESET}\n"
  printf "    ${CYAN}init${RESET} <name>      Create a new Axon workspace\n"
  printf "    ${CYAN}start${RESET}            Start Axon services\n"
  printf "    ${CYAN}stop${RESET}             Stop Axon services\n"
  printf "    ${CYAN}restart${RESET}          Restart Axon services\n"
  printf "    ${CYAN}logs${RESET} [service]   Tail logs (optionally for one service)\n"
  printf "    ${CYAN}status${RESET}           Show running services\n"
  printf "    ${CYAN}update${RESET}           Pull latest Axon images\n"
  printf "    ${CYAN}doctor${RESET}           Check system dependencies\n"
  printf "    ${CYAN}self-update${RESET}      Update the Axon CLI itself\n"
  printf "    ${CYAN}version${RESET}          Show version\n"
  printf "\n"
  printf "  ${BOLD}Start options:${RESET}\n"
  printf "    ${DIM}--local${RESET}          Enable local LLMs via Ollama\n"
  printf "    ${DIM}--search${RESET}         Enable web search via SearXNG\n"
  printf "\n"
  printf "  ${BOLD}Examples:${RESET}\n"
  printf "    ${DIM}axon init my-workspace${RESET}\n"
  printf "    ${DIM}cd my-workspace && axon start${RESET}\n"
  printf "    ${DIM}axon start --local --search${RESET}\n"
  printf "\n"
}

# ── Main ────────────────────────────────────────────────────────────────────
main() {
  local cmd="${1:-}"
  shift 2>/dev/null || true

  case "$cmd" in
    init)        cmd_init "$@" ;;
    start)       cmd_start "$@" ;;
    stop)        cmd_stop "$@" ;;
    restart)     cmd_restart "$@" ;;
    logs)        cmd_logs "$@" ;;
    status)      cmd_status "$@" ;;
    update)      cmd_update "$@" ;;
    doctor)      cmd_doctor "$@" ;;
    self-update) cmd_self_update "$@" ;;
    version|-v|--version) cmd_version ;;
    help|-h|--help|"") usage ;;
    *)
      fail "Unknown command: $cmd (run 'axon help' for usage)"
      ;;
  esac
}

main "$@"
