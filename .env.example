# Axon — Configuration
# Copy this file to .env and fill in your values

# API Keys (at least one required)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Default model for all agents (override per-agent in persona YAMLs)
# LiteLLM format: provider/model-name
# Examples:
#   anthropic/claude-sonnet-4-20250514
#   openai/gpt-4o
#   ollama/llama3:8b
DEFAULT_MODEL=anthropic/claude-sonnet-4-20250514

# Multi-org root — all orgs, vaults, and data live here
# Structure: orgs/{org-name}/vaults/{agent-name}/
# Keep this outside the project directory for clean separation
AXON_ORGS_DIR=./orgs

# Optional: Ollama for local LLMs
# Start with: docker compose --profile local-llm up
# OLLAMA_BASE_URL is auto-configured for the Docker network
#
# OLLAMA_MODEL controls which reasoning model gets auto-pulled on first start.
# llama3:8b is always pulled as the default navigator model.
# Examples: qwen2.5:14b, mistral-small:24b, phi4:14b, llama3.1:8b
OLLAMA_MODEL=qwen2.5:14b

# Database — SQLite by default, Postgres when you're ready to scale
# Leave empty for auto-derived SQLite at {AXON_ORGS_DIR}/data/axon.db
# Postgres example: postgresql+asyncpg://user:pass@localhost/axon
DATABASE_URL=

# Encryption key for OAuth tokens stored in the database (required)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DB_ENCRYPTION_KEY=
