# Axon — Configuration
# Copy this file to .env and fill in your values

# API Keys (at least one required)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Vault paths (absolute paths on your host machine)
# These get mounted into the container as Docker volumes
MARCUS_VAULT=
RAJ_VAULT=
DIANA_VAULT=
BOARDROOM_VAULT=
EA_MEMORY=

# Optional: Ollama for local LLMs
# Start with: docker compose --profile local-llm up
# OLLAMA_BASE_URL is auto-configured for the Docker network
